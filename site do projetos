<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Painel de Controle</title>

<style>

/* Reset básico */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, Helvetica, sans-serif;
}

/* GRID PRINCIPAL */
.container{
    display:grid;
    grid-template-columns: 220px 1fr;
    grid-template-rows: 70px 1fr;
    grid-template-areas:
        "sidebar header"
        "sidebar main";
    height:100vh;
}

/* MENU LATERAL */
.sidebar{
    grid-area: sidebar;
    background:#2c3e50;
    color:white;
    padding:20px;

    /* FLEXBOX */
    display:flex;
    flex-direction:column;
    gap:15px;
}

.sidebar h2{
    margin-bottom:10px;
}

.sidebar ul{
    list-style:none;

    display:flex;
    flex-direction:column;
    gap:10px;
}

.sidebar li{
    padding:8px;
    cursor:pointer;
}

.sidebar li:hover{
    background:#34495e;
    border-radius:5px;
}

/* CABEÇALHO */
.header{
    grid-area: header;
    background:#ecf0f1;
    padding:20px;

    display:flex;
    justify-content:space-between;
    align-items:center;
}

.header button{
    padding:10px 20px;
    border:none;
    background:#3498db;
    color:white;
    border-radius:5px;
    cursor:pointer;

    /* TRANSIÇÃO */
    transition: background 0.3s ease;
}

.header button:hover{
    background:#1d6fa5;
}

/* CONTEÚDO PRINCIPAL */
.main{
    grid-area: main;
    padding:20px;

    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
    gap:20px;
}

/* CAIXAS */
.card{
    background:white;
    padding:20px;
    border-radius:8px;
    box-shadow:0 3px 8px rgba(0,0,0,0.1);

    /* ANIMAÇÃO */
    animation: slideIn 0.8s ease forwards;
}

/* Delay para aparecer uma depois da outra */
.card:nth-child(2){
    animation-delay:0.2s;
}

.card:nth-child(3){
    animation-delay:0.4s;
}

/* KEYFRAMES */
@keyframes slideIn{
    from{
        opacity:0;
        transform:translateX(50px);
    }
    to{
        opacity:1;
        transform:translateX(0);
    }
}

/* RESPONSIVO */
@media(max-width:768px){
    .container{
        grid-template-columns: 1fr;
        grid-template-rows: auto auto 1fr;
        grid-template-areas:
            "header"
            "sidebar"
            "main";
    }

    .sidebar{
        flex-direction:row;
        overflow-x:auto;
    }

    .sidebar ul{
        flex-direction:row;
    }
}

</style>
</head>

<body>

<div class="container">

    <!-- MENU LATERAL -->
    <aside class="sidebar">
        <h2>Menu</h2>
        <ul>
            <li>Dashboard</li>
            <li>Usuários</li>
            <li>Relatórios</li>
            <li>Configurações</li>
        </ul>
    </aside>

    <!-- CABEÇALHO -->
    <header class="header">
        <h1>Painel de Controle</h1>
        <button>Entrar</button>
    </header>

    <!-- CONTEÚDO -->
    <main class="main">
        <div class="card">Conteúdo 1</div>
        <div class="card">Conteúdo 2</div>
        <div class="card">Conteúdo 3</div>
    </main>

</div>

</body>
</html>
